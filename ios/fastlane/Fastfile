# Fastlane lanes for iOS (Flutter)
# Docs: https://docs.fastlane.tools

default_platform(:ios)

PROJECT_ROOT = File.expand_path("../..", __dir__)
APP_IDENTIFIER = "com.fastline.ci"
IPA_OUTPUT_DIR = File.join(PROJECT_ROOT, "build/ios/ipa")
XCODEPROJ_PATH = File.join(PROJECT_ROOT, "ios/Runner.xcodeproj")

platform :ios do
  desc "Run Flutter unit/widget tests"
  lane :test do
    sh("cd #{PROJECT_ROOT} && flutter test")
  end

  desc "Install CocoaPods dependencies"
  lane :pods do
    cocoapods(
      podfile: File.join(PROJECT_ROOT, "ios/Podfile"),
      try_repo_update_on_error: true
    )
  end

  desc "Sync code signing certificates via match (App Store)"
  lane :sync_certificates do
    match(type: "appstore", readonly: is_ci)
  end

  desc "Build iOS app without code signing (CI smoke build)"
  lane :build_ci do
    sh("cd #{PROJECT_ROOT} && flutter build ios --release --no-codesign")
  end

  desc "Build IPA for App Store / TestFlight"
  lane :build do
    setup_ci if is_ci

    sync_certificates if ENV["USE_MATCH"] == "true" || is_ci

    profile_name = ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"] || "match AppStore #{APP_IDENTIFIER}"
    profile_path = ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-path"]
    team_id = ENV["sigh_#{APP_IDENTIFIER}_appstore_team-id"] || ENV["APPLE_TEAM_ID"] || "YQ339GL7HY"

    install_provisioning_profile(path: profile_path) if profile_path && !profile_path.empty?

    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ_PATH,
      targets: ["Runner"],
      build_configurations: ["Release"],
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      team_id: team_id,
      bundle_identifier: APP_IDENTIFIER
    )

    sh("cd #{PROJECT_ROOT} && flutter pub get")
    sh("cd #{PROJECT_ROOT} && flutter build ios --release --no-codesign")

    gym(
      workspace: File.join(PROJECT_ROOT, "ios/Runner.xcworkspace"),
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: IPA_OUTPUT_DIR,
      output_name: "Runner.ipa",
      clean: false,
      skip_profile_detection: true,
      codesigning_identity: "Apple Distribution",
      export_options: {
        method: "app-store",
        teamID: team_id,
        signingStyle: "manual",
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      },
      xcargs: [
        "DEVELOPMENT_TEAM=#{team_id}",
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY=Apple Distribution",
        "PROVISIONING_PROFILE_SPECIFIER=#{profile_name}"
      ].join(" ")
    )
  end

  desc "Upload build to TestFlight"
  lane :beta do
    build

    upload_to_testflight(
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Submit to App Store review"
  lane :release do
    build

    upload_to_app_store(
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false
    )
  end
end
